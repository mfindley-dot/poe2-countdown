{
  "manifest_version": 3,
  "name": "GLG PoE2 Stash Scanner",
  "version": "1.0",
  "description": "Graphic screen capture, Gemini Vision OCR, and serverless database synchronization for GLG PoE2 Guild Vault.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "storage",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://dreamlo.com/*",
    "http://dreamlo.com/*",
    "https://corsproxy.io/*",
    "https://*.pathofexile.com/*",
    "https://pathofexile.com/*",
    "https://*.pathofexile2.com/*",
    "https://pathofexile2.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.pathofexile.com/*",
        "https://pathofexile.com/*",
        "https://*.pathofexile2.com/*",
        "https://pathofexile2.com/*"
      ],
      "js": ["content_script.js"]
    }
  ]
}
